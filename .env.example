
# ── DATABASE (Neon Postgres) ───────────────────────────────────────────
# Neon Console → Connection details: pooled → DATABASE_URL, direct → DIRECT_URL
# (pooler биш direct host ашиглана — migrate зориулсан)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Хэрэв Neon биш, зөвхөн local Docker Postgres ашиглах бол:
#   docker compose --profile local-postgres up -d postgres redis
#   DATABASE_URL="postgresql://elearn:elearn_password@localhost:15432/elearn_db"
#   DIRECT_URL="postgresql://elearn:elearn_password@localhost:15432/elearn_db"

# Neon pooler URL байвал pg adapter автоматаар асаана. Гараар: true | false
# PRISMA_USE_PG_ADAPTER="true"

# Local Docker Redis асаахгүй (Upstash эсвэл гадны Redis) — dev:safe-д Docker ажиллуулахгүй
# SKIP_DOCKER_REDIS="1"

# ── AUTH ────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""              # openssl rand -base64 32
# Auth.js v5: AUTH_SECRET нь NEXTAUTH_SECRET-ээс илүүдүүлэгдэнэ (аль нэгийг заавал бөглө)
AUTH_SECRET=""
SOCKET_AUTH_SECRET=""           # use the same value on Next.js and the socket server

# Google OAuth — хоёулаа бөглөгдсөн үед л Google нэвтрэлт идэвхтэй
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── REDIS ───────────────────────────────────────────────────────────
# Local: redis://localhost:16379
# Upstash: rediss://default:TOKEN@HOST.upstash.io:6380
REDIS_URL="redis://localhost:16379"

# ── AI (Groq) — сервер талд л (хэрэглэгчид илгээхгүй) ───────────────────────
GROQ_API_KEY=""
# Local: .env эсвэл .env.local дотор байрлуулна. Түлхүүр нэмсний дараа `npm run dev` дахин асаана.
# Vercel: Project → Settings → Environment Variables (Production/Preview) — client bundle-д бүү оруулна.
# Үндсэн: llama-3.3-70b-versatile · Нөөц: llama-3.1-8b-instant (кодоор тохируулсан)

# Supabase realtime chat
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# ── EMAIL ───────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""                # Gmail App Password
EMAIL_FROM="ELearn <noreply@yourdomain.com>"
RESEND_API_KEY=""               # Resend.com alternative

# ── STORAGE ─────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-1"
AWS_S3_BUCKET=""

# ── STRIPE ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""            # sk_live_ эсвэл sk_test_
STRIPE_PUBLISHABLE_KEY=""       # pk_live_ эсвэл pk_test_
STRIPE_WEBHOOK_SECRET=""        # whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PREMIUM_MONTHLY_PRICE_ID=""
STRIPE_PREMIUM_YEARLY_PRICE_ID=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# ─── AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""            # Required for real Robo AI responses

# ── MONITORING (Sentry) ─────────────────────────────────────────────
# https://sentry.io дээр project үүсгэж DSN авна
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""                   # Sentry organization slug
SENTRY_PROJECT=""               # Sentry project slug
SENTRY_AUTH_TOKEN=""            # Source map upload зориулсан

# ── APP ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EduNity"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
SOCKET_PORT="4000"
